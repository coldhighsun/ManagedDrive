<Window x:Class="ManagedDrive.App.Views.PasswordPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindow}"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppDivider}"
            BorderThickness="1"
            CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="18" ShadowDepth="2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Draggable title bar -->
            <Border Grid.Row="0"
                    Background="Transparent"
                    Padding="20,14,20,14"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="20"
                               Text="&#xE72E;"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppForeground}"/>
                    <TextBlock x:Name="TitleText"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               FontSize="16" FontWeight="Medium"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="24,0,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Disk info card: volume label, drive letter, capacity in separate columns -->
                <Border x:Name="DiskInfoPanel" Grid.Row="0"
                        Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppDivider}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,10"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource PasswordPrompt.LabelHeader}"
                                       FontSize="11" Opacity="0.6"/>
                            <TextBlock x:Name="DiskLabelText"
                                       FontWeight="Medium" Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{DynamicResource PasswordPrompt.DriveHeader}"
                                       FontSize="11" Opacity="0.6"/>
                            <TextBlock x:Name="DiskDriveText"
                                       FontWeight="Medium" Margin="0,2,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource PasswordPrompt.SizeHeader}"
                                       FontSize="11" Opacity="0.6"/>
                            <TextBlock x:Name="DiskSizeText"
                                       FontWeight="Medium" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Password input -->
                <PasswordBox x:Name="PasswordInput" Grid.Row="2"/>

                <!-- Error text -->
                <TextBlock x:Name="ErrorText" Grid.Row="4"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AppWarning}"
                           Visibility="Collapsed"/>

                <!-- Buttons -->
                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource Btn.Cancel}" Width="80" IsCancel="True"
                            Style="{StaticResource FlatButton}"
                            Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource Btn.Ok}" Width="80" IsDefault="True"
                            Click="OkButton_Click"
                            Style="{StaticResource RaisedButton}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

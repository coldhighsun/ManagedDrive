<Window x:Class="ManagedDrive.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ManagedDrive.App.ViewModels"
        mc:Ignorable="d"
        Style="{StaticResource MaterialDesignWindow}"
        Icon="pack://application:,,,/ManagedDrive.ico"
        Title="{DynamicResource Window.Title}"
        Height="480" Width="760"
        MinHeight="320" MinWidth="520"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignBackground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <DockPanel>

        <!-- App bar -->
        <materialDesign:ColorZone Mode="PrimaryMid" DockPanel.Dock="Top"
                                   Padding="4,4,4,4"
                                   materialDesign:ElevationAssist.Elevation="Dp4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource MaterialDesignToolButton}"
                            Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                            Command="{Binding CreateDiskCommand}"
                            ToolTip="{DynamicResource Tip.NewDisk}">
                        <materialDesign:PackIcon Kind="PlusCircle" Width="22" Height="22"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignToolButton}"
                            Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                            Command="{Binding UnmountCommand}"
                            ToolTip="{DynamicResource Tip.Unmount}">
                        <materialDesign:PackIcon Kind="Eject" Width="22" Height="22"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignToolButton}"
                            Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                            Command="{Binding SaveImageCommand}"
                            ToolTip="{DynamicResource Tip.SaveImage}">
                        <materialDesign:PackIcon Kind="ContentSave" Width="22" Height="22"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignToolButton}"
                            Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                            Command="{Binding RefreshCommand}"
                            ToolTip="{DynamicResource Tip.Refresh}">
                        <materialDesign:PackIcon Kind="Refresh" Width="22" Height="22"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignToolButton}"
                            Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                            Command="{Binding SettingsCommand}"
                            ToolTip="{DynamicResource Tip.Settings}">
                        <materialDesign:PackIcon Kind="Cog" Width="22" Height="22"/>
                    </Button>
                    <materialDesign:PopupBox PlacementMode="BottomAndAlignRightEdges"
                                             Foreground="{DynamicResource PrimaryHueMidForegroundBrush}">
                        <StackPanel MinWidth="140" Margin="4">
                            <Button Content="{DynamicResource Menu.Exit}"
                                    Command="{Binding ExitCommand}"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource MaterialDesignFlatButton}"/>
                        </StackPanel>
                    </materialDesign:PopupBox>
                </StackPanel>
                <TextBlock VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           FontSize="16" FontWeight="Medium"
                           Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                           Text="{DynamicResource Window.Title}"/>
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="11"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"/>
        </Border>

        <!-- Disk card list -->
        <ListBox ItemsSource="{Binding Disks}"
                 SelectedItem="{Binding SelectedDisk}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0,4"
                 Tag="{Binding}">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{DynamicResource Btn.NewDisk}"
                              Command="{Binding PlacementTarget.Tag.CreateDiskCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="PlusCircle"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:DiskViewModel}">
                    <materialDesign:Card x:Name="Card"
                                         Margin="12,4"
                                         Padding="16"
                                         materialDesign:ElevationAssist.Elevation="Dp2"
                                         Cursor="Hand"
                                         Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                        <materialDesign:Card.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource Btn.OpenInExplorer}"
                                          Command="{Binding PlacementTarget.DataContext.OpenInExplorerCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                    <MenuItem.Icon>
                                        <materialDesign:PackIcon Kind="FolderOpen"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="{DynamicResource Btn.Unmount}"
                                          Command="{Binding PlacementTarget.Tag.UnmountCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                    <MenuItem.Icon>
                                        <materialDesign:PackIcon Kind="Eject"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{DynamicResource Btn.SaveImage}"
                                          Command="{Binding PlacementTarget.Tag.SaveImageCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                    <MenuItem.Icon>
                                        <materialDesign:PackIcon Kind="ContentSave"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </materialDesign:Card.ContextMenu>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Drive letter badge -->
                            <Border Width="44" Height="44" CornerRadius="8"
                                    Background="{DynamicResource PrimaryHueMidBrush}">
                                <TextBlock Text="{Binding MountPoint}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Label + progress bar + used/capacity -->
                            <StackPanel Grid.Column="1" Margin="12,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding VolumeLabel}"
                                           FontSize="14" FontWeight="Medium"/>
                                <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}"
                                             Minimum="0" Maximum="100"
                                             Value="{Binding UsedPercent, Mode=OneWay}"
                                             Height="4" Margin="0,6,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding UsedFormatted}" FontSize="12"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock Text=" / " FontSize="12"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock Text="{Binding CapacityFormatted}" FontSize="12"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Free space -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding FreeFormatted}"
                                           FontSize="14" FontWeight="Medium"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Text="{DynamicResource Col.Free}" FontSize="11"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>
                    <DataTemplate.Triggers>
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <Binding Path="IsSelected"
                                         RelativeSource="{RelativeSource AncestorType=ListBoxItem}"/>
                            </DataTrigger.Binding>
                            <Setter TargetName="Card" Property="materialDesign:ElevationAssist.Elevation" Value="Dp8"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>
</Window>

<Window x:Class="ManagedDrive.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ManagedDrive.App.ViewModels"
        mc:Ignorable="d"
        Style="{StaticResource AppWindow}"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="pack://application:,,,/ManagedDrive.ico"
        Title="{DynamicResource Window.Title}"
        Height="480" Width="760"
        MinHeight="320" MinWidth="520"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource AppForeground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48"
                      ResizeBorderThickness="4"
                      GlassFrameThickness="0"
                      NonClientFrameEdges="None"/>
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppDivider}"
            BorderThickness="1"
            CornerRadius="10"
            ClipToBounds="True">
    <Grid>
    <DockPanel>

        <!-- App bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource AppBarBackground}"
                CornerRadius="9,9,0,0"
                Padding="4,4,4,4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding CreateDiskCommand}"
                            ToolTip="{DynamicResource Tip.NewDisk}">
                        <TextBlock Style="{StaticResource IconText}" Text="&#xE710;"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding ResetTempDirsCommand}"
                            ToolTip="{DynamicResource Tip.ResetTempDirs}">
                        <TextBlock Style="{StaticResource IconText}" Text="&#xE7A7;"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding SettingsCommand}"
                            ToolTip="{DynamicResource Tip.Settings}">
                        <TextBlock Style="{StaticResource IconText}" Text="&#xE713;"/>
                    </Button>
                    <Button x:Name="OverflowBtn" Style="{StaticResource IconButton}"
                            Click="OverflowBtn_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="OverflowMenu">
                                <MenuItem Header="{DynamicResource Menu.About}"
                                          Command="{Binding AboutCommand}"/>
                                <MenuItem Header="{DynamicResource Menu.Exit}"
                                          Command="{Binding ExitCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <TextBlock Style="{StaticResource IconText}" Text="&#xE712;"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}"
                            Click="MinimizeButton_Click"
                            ToolTip="{DynamicResource Tip.Minimize}">
                        <TextBlock Style="{StaticResource IconText}" Text="&#xE921;" FontSize="12"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}"
                            Click="CloseButton_Click"
                            ToolTip="{DynamicResource Tip.HideToTray}">
                        <TextBlock Style="{StaticResource IconText}" Text="&#xE8BB;"/>
                    </Button>
                </StackPanel>
                <TextBlock VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           FontSize="16" FontWeight="Medium"
                           Foreground="{DynamicResource AppBarForeground}"
                           Text="{DynamicResource Window.Title}"/>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource AppToolBarBackground}"
                BorderBrush="{DynamicResource AppDivider}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,9,9"
                Padding="12,4">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="11"
                       Foreground="{DynamicResource AppForegroundLight}"/>
        </Border>

        <!-- Disk card list -->
        <ListBox ItemsSource="{Binding Disks}"
                 SelectedItem="{Binding SelectedDisk}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0,4"
                 Tag="{Binding}">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{DynamicResource Btn.NewDisk}"
                              Command="{Binding PlacementTarget.Tag.CreateDiskCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="{DynamicResource Btn.ImportDisk}"
                              ToolTip="{DynamicResource Tip.ImportDisk}"
                              Command="{Binding PlacementTarget.Tag.ImportDiskCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="{DynamicResource Btn.ImportArchive}"
                              ToolTip="{DynamicResource Tip.ImportArchive}"
                              Command="{Binding PlacementTarget.Tag.ImportArchiveCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:DiskViewModel}">
                    <Border x:Name="Card"
                            Style="{StaticResource DiskCard}"
                            Margin="12,4"
                            Padding="16"
                            Cursor="Hand"
                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenInExplorerCommand}"/>
                        </Border.InputBindings>
                        <Border.ContextMenu>
                            <ContextMenu>
                                <!-- Navigation -->
                                <MenuItem Header="{DynamicResource Btn.OpenInExplorer}"
                                          Command="{Binding PlacementTarget.DataContext.OpenInExplorerCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="{DynamicResource Btn.OpenImageDirectory}"
                                          Command="{Binding PlacementTarget.DataContext.OpenImageDirectoryCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <Separator/>
                                <!-- Configuration -->
                                <MenuItem Header="{DynamicResource Btn.EditDisk}"
                                          Command="{Binding PlacementTarget.Tag.EditDiskCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="{DynamicResource Btn.SetAsTempDir}"
                                          Visibility="{Binding PlacementTarget.DataContext.IsNotCurrentTempDir,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                        Converter={StaticResource BoolToVis}}"
                                          Command="{Binding PlacementTarget.Tag.ToggleTempDirCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="{DynamicResource Btn.RestoreDefaultTemp}"
                                          Visibility="{Binding PlacementTarget.DataContext.IsCurrentTempDir,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                        Converter={StaticResource BoolToVis}}"
                                          Command="{Binding PlacementTarget.Tag.ToggleTempDirCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <Separator/>
                                <!-- Destructive operations -->
                                <MenuItem Header="{DynamicResource Btn.SaveImage}"
                                          Command="{Binding PlacementTarget.Tag.SaveImageCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="{DynamicResource Btn.CloneDisk}"
                                          Command="{Binding PlacementTarget.Tag.CloneDiskCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="{DynamicResource Btn.RestoreSnapshot}"
                                          Visibility="{Binding PlacementTarget.DataContext.SnapshotsEnabled,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                        Converter={StaticResource BoolToVis}}"
                                          Command="{Binding PlacementTarget.Tag.RestoreSnapshotCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="{DynamicResource Btn.FormatDisk}"
                                          Command="{Binding PlacementTarget.Tag.FormatDiskCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="{DynamicResource Btn.Unmount}"
                                          Command="{Binding PlacementTarget.Tag.UnmountCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Drive letter badge, with read-only/temp-dir status corner icons -->
                            <Grid Width="48" Height="48" VerticalAlignment="Center">
                                <Border CornerRadius="8"
                                        Background="{DynamicResource AppPrimary}">
                                    <TextBlock Text="{Binding MountPoint}"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppPrimaryForeground}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Margin="0,0,-4,-4">
                                    <Border Width="18" Height="18" CornerRadius="9"
                                            Background="{DynamicResource AppSurface}"
                                            BorderBrush="{DynamicResource AppDivider}" BorderThickness="1"
                                            ToolTip="{DynamicResource Card.ReadOnly}"
                                            Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="&#xE72E;" Style="{StaticResource IconText}" FontSize="10"
                                                   Foreground="{DynamicResource AppForegroundLight}"/>
                                    </Border>
                                    <Border Width="18" Height="18" CornerRadius="9" Margin="2,0,0,0"
                                            Background="{DynamicResource AppSurface}"
                                            BorderBrush="{DynamicResource AppDivider}" BorderThickness="1"
                                            ToolTip="{DynamicResource Btn.RestoreDefaultTemp}"
                                            Visibility="{Binding IsCurrentTempDir, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" FontSize="10"
                                                   Foreground="{DynamicResource AppForeground}"/>
                                    </Border>
                                    <Border Width="18" Height="18" CornerRadius="9" Margin="2,0,0,0"
                                            Background="{DynamicResource AppSurface}"
                                            BorderBrush="{DynamicResource AppDivider}" BorderThickness="1"
                                            ToolTip="{Binding SourcePath}"
                                            Visibility="{Binding HasImagePath, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="&#xE74E;" Style="{StaticResource IconText}" FontSize="10"
                                                   Foreground="{DynamicResource AppForegroundLight}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Label + progress bar + used/capacity, or read-only summary -->
                            <StackPanel Grid.Column="1" Margin="12,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding VolumeLabel}"
                                           FontSize="14" FontWeight="Medium"
                                           Foreground="{DynamicResource AppForeground}"/>

                                <StackPanel Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVis}}">
                                    <TextBlock FontSize="12"
                                               Foreground="{DynamicResource AppForegroundLight}"
                                               TextTrimming="CharacterEllipsis">
                                        <Run Text="{DynamicResource Card.ReadOnly}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding SourcePath, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Visibility="{Binding IsNotReadOnly, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <ProgressBar Minimum="0" Maximum="100"
                                                     Value="{Binding UsedPercent, Mode=OneWay}">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar" BasedOn="{StaticResource SlimProgressBar}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHighUsage}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppWarning}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding UsedFormatted}" FontSize="12"
                                                   Foreground="{DynamicResource AppForegroundLight}"/>
                                        <TextBlock Text=" / " FontSize="12"
                                                   Foreground="{DynamicResource AppForegroundLight}"/>
                                        <TextBlock Text="{Binding CapacityFormatted}" FontSize="12"
                                                   Foreground="{DynamicResource AppForegroundLight}"/>
                                        <TextBlock Text="{Binding UsedPercent, StringFormat='  ({0:0}%)'}" FontSize="12"
                                                   Foreground="{DynamicResource AppForegroundLight}"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                            Visibility="{Binding IsNotReadOnly, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="&#xE823;" FontFamily="Segoe Fluent Icons" FontSize="10"
                                               Foreground="{DynamicResource AppForegroundLight}"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding LastContentWriteFormatted}"
                                               FontSize="11"
                                               Foreground="{DynamicResource AppForegroundLight}"/>
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons" FontSize="10"
                                               Foreground="{DynamicResource AppForegroundLight}"
                                               VerticalAlignment="Center" Margin="12,0,4,0"
                                               Visibility="{Binding ShowLastAutoSave, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text="{Binding LastAutoSaveFormatted}"
                                               FontSize="11"
                                               Foreground="{DynamicResource AppForegroundLight}"
                                               Visibility="{Binding ShowLastAutoSave, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Free space -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                        Visibility="{Binding IsNotReadOnly, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding FreeFormatted}"
                                           FontSize="14" FontWeight="Medium"
                                           HorizontalAlignment="Right">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource AppForeground}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHighUsage}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppWarning}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{DynamicResource Col.Free}" FontSize="11"
                                           Foreground="{DynamicResource AppForegroundLight}"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>

                            <!-- Saving overlay -->
                            <Border Grid.ColumnSpan="3"
                                    Background="{DynamicResource AppSurface}"
                                    Opacity="0.85"
                                    CornerRadius="8"
                                    Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="SavingSpinner"
                                               Text="&#xE895;" FontFamily="Segoe Fluent Icons" FontSize="16"
                                               Foreground="{DynamicResource AppPrimary}"
                                               RenderTransformOrigin="0.5,0.5">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                    <TextBlock Text="{DynamicResource Card.Saving}" FontSize="12" Margin="6,0,0,0"
                                               Foreground="{DynamicResource AppForeground}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <DataTemplate.Triggers>
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <Binding Path="IsSelected"
                                         RelativeSource="{RelativeSource AncestorType=ListBoxItem}"/>
                            </DataTrigger.Binding>
                            <Setter TargetName="Card" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.2"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSaving}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="SpinStoryboard">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                          Storyboard.TargetProperty="Angle"
                                                          From="0" To="360" Duration="0:0:1"
                                                          RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="SpinStoryboard"/>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>

    <!-- Exit saving overlay -->
    <Border Background="{DynamicResource AppSurface}"
            Opacity="0.92"
            Visibility="{Binding IsExiting, Converter={StaticResource BoolToVis}}"
            Panel.ZIndex="100">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="&#xE895;" FontFamily="Segoe Fluent Icons" FontSize="20"
                       Foreground="{DynamicResource AppPrimary}"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <RotateTransform x:Name="ExitSpinnerRotate" Angle="0"/>
                </TextBlock.RenderTransform>
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExiting}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="ExitSpinStoryboard">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                              From="0" To="360" Duration="0:0:1"
                                                              RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="ExitSpinStoryboard"/>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{DynamicResource Msg.ExitSaving}" FontSize="14" Margin="8,0,0,0"
                       Foreground="{DynamicResource AppForeground}" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
    </Grid>
    </Border>
</Window>

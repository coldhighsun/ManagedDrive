<Window x:Class="ManagedDrive.App.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Style="{StaticResource MaterialDesignWindow}"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignBackground}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Icon + app name -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="pack://application:,,,/ManagedDrive.ico"
                   Width="40" Height="40"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="ManagedDrive"
                           FontSize="20" FontWeight="Medium"/>
                <TextBlock x:Name="VersionText"
                           FontSize="12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Description + copyright + link -->
        <StackPanel Grid.Row="2" Margin="0">
            <TextBlock Text="{DynamicResource About.Description}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                       LineHeight="20"
                       Margin="0,0,0,10"/>
            <TextBlock Text="{DynamicResource About.Copyright}"
                       FontSize="12"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                       Margin="0,0,0,6"/>
            <TextBlock FontSize="12">
                <Hyperlink x:Name="GitHubLink" RequestNavigate="GitHubLink_RequestNavigate">
                    <Run Text="{DynamicResource About.ViewOnGitHub}"/>
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <!-- OK button -->
        <Button Grid.Row="4"
                Content="{DynamicResource Btn.Ok}"
                Width="80"
                IsDefault="True"
                IsCancel="True"
                HorizontalAlignment="Right"
                Style="{StaticResource MaterialDesignRaisedButton}"/>
    </Grid>
</Window>

<views:DialogWindowBase x:Class="ManagedDrive.App.Views.CreateDiskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ManagedDrive.App.Views"
        Style="{StaticResource DialogWindowStyle}"
        Title="{DynamicResource CreateDisk.Title}"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" x:Name="MainTabControl" Style="{StaticResource AppTabControl}" MinHeight="390">

            <!-- Basic Info -->
            <TabItem Header="{DynamicResource CreateDisk.Section.Basic}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Drive Letter -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource CreateDisk.DriveLetter}"
                                   Foreground="{DynamicResource AppForeground}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="2" x:Name="DriveLetterBox" IsEditable="False"
                                  Style="{StaticResource OutlinedComboBox}"/>
                    </Grid>

                    <!-- Capacity -->
                    <Grid Grid.Row="2" x:Name="CapacityRow" Style="{StaticResource DimWhenDisabled}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource CreateDisk.Capacity}"
                                   Foreground="{DynamicResource AppForeground}"
                                   VerticalAlignment="Center"/>
                        <Slider Grid.Column="2" x:Name="CapacitySlider"
                                ToolTip="{DynamicResource Tip.Capacity}"
                                Style="{StaticResource AppSlider}"
                                Minimum="1" Maximum="999999" Value="2"
                                ValueChanged="CapacitySlider_ValueChanged"/>
                        <TextBlock Grid.Column="4" x:Name="CapacityValueText"
                                   Foreground="{DynamicResource AppForeground}"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                        <ComboBox Grid.Column="6" x:Name="CapacityUnitBox" IsEditable="False"
                                  Style="{StaticResource OutlinedComboBox}"/>
                    </Grid>

                    <!-- Volume Label -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource CreateDisk.VolumeLabel}"
                                   Foreground="{DynamicResource AppForeground}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" x:Name="VolumeLabelBox" MaxLength="32"
                                 Style="{StaticResource OutlinedTextBox}"/>
                    </Grid>

                    <!-- High Usage Warning -->
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="HighUsageWarnBox" IsChecked="True"
                                  Content="{DynamicResource CreateDisk.HighUsageWarn}"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource AppForeground}"
                                  ToolTip="{DynamicResource Tip.HighUsageWarn}"
                                  Checked="HighUsageWarnBox_CheckedChanged" Unchecked="HighUsageWarnBox_CheckedChanged"/>
                        <Grid Grid.Column="2" x:Name="HighUsageWarnPercentPanel" IsEnabled="False" VerticalAlignment="Center"
                              Style="{StaticResource DimWhenDisabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="HighUsageWarnPercentSlider"
                                     ToolTip="{DynamicResource Tip.HighUsageWarn}"
                                     Style="{StaticResource AppSlider}"
                                     Minimum="1" Maximum="99" Value="90"
                                     ValueChanged="HighUsageWarnPercentSlider_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="HighUsageWarnPercentValueText"
                                       Foreground="{DynamicResource AppForeground}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>

                    <!-- Auto Mount -->
                    <CheckBox Grid.Row="8" x:Name="AutoMountBox" IsChecked="True"
                              Content="{DynamicResource CreateDisk.AutoMount}"
                              Foreground="{DynamicResource AppForeground}"
                              ToolTip="{DynamicResource Tip.AutoMount}"/>

                    <!-- Read Only -->
                    <CheckBox Grid.Row="10" x:Name="ReadOnlyBox"
                              Content="{DynamicResource CreateDisk.ReadOnly}"
                              Foreground="{DynamicResource AppForeground}"
                              ToolTip="{DynamicResource Tip.ReadOnly}"
                              Checked="ReadOnlyBox_CheckedChanged" Unchecked="ReadOnlyBox_CheckedChanged"/>
                </Grid>
            </TabItem>

            <!-- Persistence -->
            <TabItem x:Name="PersistenceTabItem" Header="{DynamicResource CreateDisk.Section.Persistence}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Image Path -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="ImagePathLabel" Text="{DynamicResource CreateDisk.ImageFile}"
                                   Foreground="{DynamicResource AppForeground}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" x:Name="ImagePathBox" IsReadOnly="True" Cursor="Hand"
                                 ToolTip="{DynamicResource Tip.ImageFile}"
                                 Style="{StaticResource OutlinedTextBox}"
                                 PreviewMouseLeftButtonDown="ImagePathBox_PreviewMouseLeftButtonDown"/>
                        <Button Grid.Column="4" x:Name="ClearImagePathButton" Content="&#xD7;" Width="40"
                                ToolTip="{DynamicResource Tip.ClearImagePath}"
                                Click="ClearImagePath_Click"
                                Style="{StaticResource OutlinedButton}"/>
                    </Grid>

                    <!-- Import Note -->
                    <TextBlock Grid.Row="1" x:Name="ImportNoteText"
                               Text="{DynamicResource CreateDisk.ImportNote}"
                               Foreground="{DynamicResource AppForegroundLight}"
                               FontSize="11" TextWrapping="Wrap" Margin="92,0,0,0"
                               Visibility="Collapsed"/>

                    <!-- Archive Import Note -->
                    <TextBlock Grid.Row="2" x:Name="ArchiveImportNoteText"
                               Text="{DynamicResource CreateDisk.ArchiveImportNote}"
                               Foreground="{DynamicResource AppForegroundLight}"
                               FontSize="11" TextWrapping="Wrap" Margin="92,0,0,0"
                               Visibility="Collapsed"/>

                    <!-- Compression Level -->
                    <Grid Grid.Row="4" x:Name="CompressionLevelRow" Style="{StaticResource DimWhenDisabled}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource CreateDisk.CompressionLevel}"
                                   Foreground="{DynamicResource AppForeground}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="2" x:Name="CompressionLevelBox" IsEditable="False"
                                  ToolTip="{DynamicResource Tip.CompressionLevel}"
                                  Style="{StaticResource OutlinedComboBox}"
                                  SelectionChanged="CompressionLevelBox_SelectionChanged"/>
                    </Grid>

                    <!-- Compression Warning -->
                    <TextBlock Grid.Row="5" x:Name="CompressionWarningText"
                               Text="{DynamicResource CreateDisk.CompressionWarning}"
                               Foreground="{DynamicResource AppWarning}"
                               FontSize="11" TextWrapping="Wrap" Margin="92,0,0,0"
                               Visibility="Collapsed"/>

                    <!-- Save On Exit -->
                    <CheckBox Grid.Row="7" x:Name="SaveOnExitBox" VerticalAlignment="Center" IsChecked="True"
                              Content="{DynamicResource CreateDisk.SaveOnExit}"
                              Foreground="{DynamicResource AppForeground}"
                              ToolTip="{DynamicResource Tip.SaveOnExit}"/>

                    <Border Grid.Row="8" BorderBrush="{DynamicResource AppDivider}" BorderThickness="0,1,0,0"
                            VerticalAlignment="Center"/>

                    <!-- Encryption -->
                    <CheckBox Grid.Row="9" x:Name="EncryptImageBox" VerticalAlignment="Center"
                              Content="{DynamicResource CreateDisk.EncryptImage}"
                              Foreground="{DynamicResource AppForeground}"
                              ToolTip="{DynamicResource Tip.EncryptImage}"
                              Checked="EncryptImageBox_CheckedChanged" Unchecked="EncryptImageBox_CheckedChanged"/>

                    <Grid Grid.Row="11" x:Name="PasswordPanel" IsEnabled="False" Style="{StaticResource DimWhenDisabled}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource CreateDisk.Password}"
                                   Foreground="{DynamicResource AppForeground}" VerticalAlignment="Center"/>
                        <PasswordBox Grid.Row="0" Grid.Column="2" x:Name="PasswordBox1"
                                     PasswordChanged="PasswordBox1_PasswordChanged"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource CreateDisk.ConfirmPassword}"
                                   Foreground="{DynamicResource AppForeground}" VerticalAlignment="Center"/>
                        <PasswordBox Grid.Row="2" Grid.Column="2" x:Name="PasswordBox2"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" x:Name="PasswordStrengthText"
                                   FontSize="11" Visibility="Collapsed"/>
                    </Grid>

                    <!-- Section divider: image/compression/encryption above, auto-save/snapshots below -->
                    <Border Grid.Row="12" BorderBrush="{DynamicResource AppDivider}" BorderThickness="0,1,0,0"
                            VerticalAlignment="Center"/>

                    <!-- Auto Save -->
                    <Grid Grid.Row="13">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="AutoSaveBox" VerticalAlignment="Center"
                                  Content="{DynamicResource CreateDisk.AutoSave}"
                                  Foreground="{DynamicResource AppForeground}"
                                  ToolTip="{DynamicResource Tip.AutoSave}"
                                  Checked="AutoSaveBox_CheckedChanged" Unchecked="AutoSaveBox_CheckedChanged"/>
                        <Grid Grid.Column="2" x:Name="AutoSaveIntervalPanel" IsEnabled="False" VerticalAlignment="Center"
                              Style="{StaticResource DimWhenDisabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="AutoSaveIntervalSlider"
                                     ToolTip="{DynamicResource Tip.AutoSaveInterval}"
                                     Style="{StaticResource AppSlider}"
                                     Minimum="1" Maximum="60" Value="10"
                                     ValueChanged="AutoSaveIntervalSlider_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="AutoSaveIntervalValueText"
                                       Foreground="{DynamicResource AppForeground}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>

                    <!-- Snapshot Max Count -->
                    <Grid Grid.Row="15" Margin="16,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="SnapshotCountEnabledBox" VerticalAlignment="Center"
                                  Content="{DynamicResource CreateDisk.SnapshotMaxCount}"
                                  Foreground="{DynamicResource AppForeground}"
                                  ToolTip="{DynamicResource Tip.SnapshotMaxCount}"
                                  Checked="SnapshotLimit_CheckedChanged" Unchecked="SnapshotLimit_CheckedChanged"/>
                        <Grid Grid.Column="2" x:Name="SnapshotCountPanel" IsEnabled="False" VerticalAlignment="Center"
                              Style="{StaticResource DimWhenDisabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="SnapshotCountSlider"
                                     Style="{StaticResource AppSlider}"
                                     Minimum="1" Maximum="20" Value="10"
                                     ValueChanged="SnapshotCountSlider_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="SnapshotCountValueText"
                                       Foreground="{DynamicResource AppForeground}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>

                    <!-- Snapshot Max Size -->
                    <Grid Grid.Row="16" Margin="16,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="SnapshotSizeEnabledBox" VerticalAlignment="Center"
                                  Content="{DynamicResource CreateDisk.SnapshotMaxSize}"
                                  Foreground="{DynamicResource AppForeground}"
                                  ToolTip="{DynamicResource Tip.SnapshotMaxSize}"
                                  Checked="SnapshotLimit_CheckedChanged" Unchecked="SnapshotLimit_CheckedChanged"/>
                        <Grid Grid.Column="2" x:Name="SnapshotSizePanel" IsEnabled="False" VerticalAlignment="Center"
                              Style="{StaticResource DimWhenDisabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="SnapshotSizeSlider"
                                    Style="{StaticResource AppSlider}"
                                    Minimum="1" Maximum="999999" Value="500"
                                    ValueChanged="SnapshotSizeSlider_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="SnapshotSizeValueText"
                                       Foreground="{DynamicResource AppForeground}"
                                       VerticalAlignment="Center" TextAlignment="Right"/>
                            <ComboBox Grid.Column="4" x:Name="SnapshotSizeUnitBox" IsEditable="False"
                                      Style="{StaticResource OutlinedComboBox}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn.Cancel}" Width="80" IsCancel="True"
                    Style="{StaticResource FlatButton}"
                    Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Btn.Ok}" Width="80" IsDefault="True"
                    Click="OK_Click"
                    Style="{StaticResource RaisedButton}"/>
        </StackPanel>
    </Grid>
</views:DialogWindowBase>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- MainWindow -->
    <sys:String x:Key="Window.Title">ManagedDrive – RAM Disk Manager</sys:String>
    <sys:String x:Key="Menu.File">_File</sys:String>
    <sys:String x:Key="Menu.Tools">_Tools</sys:String>
    <sys:String x:Key="Menu.Exit">E_xit</sys:String>
    <sys:String x:Key="Menu.About">About</sys:String>
    <sys:String x:Key="Btn.NewDisk">New Disk</sys:String>
    <sys:String x:Key="Btn.OpenInExplorer">Open in Explorer</sys:String>
    <sys:String x:Key="Btn.EditDisk">Edit Disk…</sys:String>
    <sys:String x:Key="Btn.Unmount">Unmount</sys:String>
    <sys:String x:Key="Btn.SaveImage">Save Image</sys:String>
    <sys:String x:Key="Btn.SetAsTempDir">Set as Temp Directory</sys:String>
    <sys:String x:Key="Btn.RestoreDefaultTemp">Restore Default Temp Directory</sys:String>
    <sys:String x:Key="Btn.FormatDisk">Format…</sys:String>
    <sys:String x:Key="Btn.Refresh">Refresh</sys:String>
    <sys:String x:Key="Btn.Settings">Settings</sys:String>
    <sys:String x:Key="Tip.NewDisk">Create and mount a new RAM disk</sys:String>
    <sys:String x:Key="Tip.Unmount">Unmount the selected disk</sys:String>
    <sys:String x:Key="Tip.SaveImage">Save the selected disk's contents to its image file</sys:String>
    <sys:String x:Key="Tip.Refresh">Refresh usage statistics</sys:String>
    <sys:String x:Key="Tip.Settings">Application settings</sys:String>
    <sys:String x:Key="Tip.ResetTempDirs">Reset Windows Temp Directories to defaults</sys:String>
    <sys:String x:Key="Tip.Minimize">Minimize</sys:String>
    <sys:String x:Key="Tip.Close">Hide to tray</sys:String>
    <sys:String x:Key="Col.MountPoint">Mount Point</sys:String>
    <sys:String x:Key="Col.Label">Label</sys:String>
    <sys:String x:Key="Col.Capacity">Capacity</sys:String>
    <sys:String x:Key="Col.Used">Used</sys:String>
    <sys:String x:Key="Col.Free">Free</sys:String>
    <sys:String x:Key="Col.Usage">Usage</sys:String>

    <!-- CreateDiskDialog -->
    <sys:String x:Key="CreateDisk.Title">Create RAM Disk</sys:String>
    <sys:String x:Key="CreateDisk.TitleEdit">Edit RAM Disk</sys:String>
    <sys:String x:Key="CreateDisk.DriveLetter">Drive Letter:</sys:String>
    <sys:String x:Key="CreateDisk.VolumeLabel">Volume Label:</sys:String>
    <sys:String x:Key="CreateDisk.Capacity">Capacity:</sys:String>
    <sys:String x:Key="CreateDisk.ReadOnly">Read Only</sys:String>
    <sys:String x:Key="CreateDisk.AutoMount">Auto-mount</sys:String>
    <sys:String x:Key="CreateDisk.ImageFile">Image File</sys:String>
    <sys:String x:Key="CreateDisk.DefaultLabel">RAM Disk</sys:String>
    <sys:String x:Key="Tip.Capacity">Disk size (select unit: MB or GB)</sys:String>
    <sys:String x:Key="Tip.AutoMount">Re-mount this disk automatically on next application start</sys:String>
    <sys:String x:Key="Tip.ImageFile">Optional: path to a .mdr image file for persistence (leave blank for volatile disk)</sys:String>
    <sys:String x:Key="Tip.ClearImagePath">Clear image file path</sys:String>

    <!-- SettingsDialog -->
    <sys:String x:Key="Settings.Title">Settings</sys:String>
    <sys:String x:Key="Settings.RunAtStartup">Run at Windows startup</sys:String>
    <sys:String x:Key="Settings.StartMinimized">Start minimized to tray</sys:String>
    <sys:String x:Key="Settings.Language">Language:</sys:String>
    <sys:String x:Key="Lang.System">System Default</sys:String>
    <sys:String x:Key="Tip.RunAtStartup">Start ManagedDrive automatically when Windows starts</sys:String>
    <sys:String x:Key="Tip.StartMinimized">Hide the main window on startup and show only the system tray icon</sys:String>

    <!-- Shared buttons -->
    <sys:String x:Key="Btn.Ok">OK</sys:String>
    <sys:String x:Key="Btn.Cancel">Cancel</sys:String>

    <!-- Tray menu -->
    <sys:String x:Key="Tray.Show">Show</sys:String>
    <sys:String x:Key="Tray.NewDisk">New Disk</sys:String>
    <sys:String x:Key="Tray.ResetTempDirs">Reset Temp Directory</sys:String>
    <sys:String x:Key="Tray.Settings">Settings…</sys:String>
    <sys:String x:Key="Tray.About">About</sys:String>
    <sys:String x:Key="Tray.Exit">Exit</sys:String>
    <sys:String x:Key="Tray.NoDisksMounted">No disks mounted</sys:String>
    <sys:String x:Key="Tray.HighUsageTitle">RAM Disk Nearly Full</sys:String>
    <sys:String x:Key="Tray.HighUsageBody">{0} ({1}) is {2:F0}% full.</sys:String>

    <!-- Status bar -->
    <sys:String x:Key="Status.Ready">Ready.</sys:String>
    <sys:String x:Key="Status.Mounted">Mounted {0} ({1}).</sys:String>
    <sys:String x:Key="Status.MountedWithCapacity">Mounted {0} ({1}, {2} MB).</sys:String>
    <sys:String x:Key="Status.AutoMountFailed">Auto-mount '{0}' failed: {1}</sys:String>
    <sys:String x:Key="Status.MountFailed">Mount failed.</sys:String>
    <sys:String x:Key="Status.ImageSaved">Image saved for {0}.</sys:String>
    <sys:String x:Key="Status.Unmounted">Unmounted {0}.</sys:String>
    <sys:String x:Key="Status.TempDirSet">Temp directory set to {0}.</sys:String>

    <!-- MessageBox bodies -->
    <sys:String x:Key="Msg.AlreadyRunning">ManagedDrive is already running.</sys:String>
    <sys:String x:Key="Msg.StartupTempReset">Your Windows Temp directory was pointing to:&#x0a;&#x0a;  {0}&#x0a;&#x0a;This RAM disk is not configured to auto-mount, so the directory would not be available. It has been automatically reset to the system default.</sys:String>
    <sys:String x:Key="Msg.WinFspMissingTitle">ManagedDrive – Missing Prerequisite</sys:String>
    <sys:String x:Key="Msg.WinFspMissingBody">WinFsp 2.1.x is required but was not detected on this system.&#x0a;&#x0a;Click Yes to open the download page, or No to exit.</sys:String>
    <sys:String x:Key="Msg.ExitConfirmTitle">ManagedDrive</sys:String>
    <sys:String x:Key="Msg.ExitConfirmBody">All mounted RAM disks will be unmounted and any unimaged data will be lost.&#x0a;&#x0a;Exit anyway?</sys:String>
    <sys:String x:Key="Msg.MountFailed">Failed to mount disk:&#x0a;{0}</sys:String>
    <sys:String x:Key="Msg.SaveImageSuccess">Image saved successfully to:&#x0a;{0}</sys:String>
    <sys:String x:Key="Msg.SaveImageFailed">Failed to save image:&#x0a;{0}</sys:String>
    <sys:String x:Key="Msg.FormatDiskConfirmTitle">Format Disk</sys:String>
    <sys:String x:Key="Msg.FormatDiskConfirmBody">Format {0} ({1})?&#x0a;&#x0a;All files and folders on this disk will be permanently deleted.</sys:String>
    <sys:String x:Key="Msg.FormatDiskReadOnly">Cannot format a read-only disk.</sys:String>
    <sys:String x:Key="Msg.FormatDiskSuccess">{0} has been formatted. All files and folders have been deleted.</sys:String>
    <sys:String x:Key="Status.FormatDisk">Formatted {0}.</sys:String>
    <sys:String x:Key="Msg.UnmountConfirmTitle">Unmount Disk</sys:String>
    <sys:String x:Key="Msg.UnmountConfirmBody">Unmount {0} ({1})?&#x0a;&#x0a;Any data not saved to an image file will be lost.</sys:String>
    <sys:String x:Key="Msg.EditDiskConfirmTitle">Edit Disk</sys:String>
    <sys:String x:Key="Msg.EditDiskConfirmBody">Edit {0} ({1})?&#x0a;&#x0a;The disk will be unmounted and remounted with the new settings. All data currently in memory will be lost.</sys:String>
    <sys:String x:Key="Msg.TempDirWillBeReset">This disk is currently your Windows Temp directory. It will be automatically reset to the system default before unmounting.</sys:String>
    <sys:String x:Key="Msg.ExitTempDirWillBeReset">Your Windows Temp directory is currently set to a RAM disk. It will be automatically reset to the system default before exiting.</sys:String>
    <sys:String x:Key="Msg.TrayExitTempResetTitle">Temp Directory on RAM Disk</sys:String>
    <sys:String x:Key="Msg.TrayExitTempResetBody">Your Windows Temp directory is set to a RAM disk. It will become inaccessible after the disk is unmounted.&#x0a;&#x0a;Reset Temp to the system default and exit?</sys:String>
    <sys:String x:Key="Msg.ResetTempConfirmTitle">Reset Temp Directories</sys:String>
    <sys:String x:Key="Msg.ResetTempConfirmBody">This will restore TEMP and TMP to their Windows default:&#x0a;&#x0a;  %USERPROFILE%\AppData\Local\Temp&#x0a;&#x0a;Continue?</sys:String>
    <sys:String x:Key="Msg.ResetTempSuccess">TEMP and TMP have been reset to their Windows defaults.</sys:String>
    <sys:String x:Key="Msg.ResetTempFailed">Failed to reset temp directories.</sys:String>
    <sys:String x:Key="Msg.SetTempDirSuccess">TEMP and TMP have been set to:&#x0a;&#x0a;  {0}</sys:String>
    <sys:String x:Key="Msg.SetTempDirFailed">Failed to set temp directory.</sys:String>
    <sys:String x:Key="Msg.SetTempDirWarningTitle">RAM Disk as Temp — Compatibility Warning</sys:String>
    <sys:String x:Key="Msg.SetTempDirWarningBody">Setting TEMP to a RAM disk may cause certain installers to fail when they try to run from this path. Known examples include WeChatWin_*.exe and other packages that are extracted to TEMP and launched by a system-level service.&#x0a;&#x0a;This happens because WinFsp drives are only visible within the current user session. If an installer is executed by a system-level process (such as the Windows Package Manager service), it cannot access user-session drive letters.&#x0a;&#x0a;Not all winget packages are affected — many install without issue.&#x0a;&#x0a;Do you want to continue?</sys:String>
    <sys:String x:Key="Msg.StartupTempAutoMountWarning">Your Windows Temp directory is set to a RAM disk ({0}).&#x0a;&#x0a;Some installers — such as WeChatWin_*.exe — may fail when extracted to this path and run by a system-level process. Not all packages are affected.&#x0a;&#x0a;You can restore the default Temp directory from the toolbar if you encounter installation errors.</sys:String>

    <!-- Validation -->
    <sys:String x:Key="Val.Title">Invalid Input</sys:String>
    <sys:String x:Key="Val.NoDriveLetter">Please select a drive letter.</sys:String>
    <sys:String x:Key="Val.BadCapacity">Capacity must be between 1 and {0} {1}.</sys:String>

    <!-- AboutDialog -->
    <sys:String x:Key="About.Description">An in-memory RAM disk for Windows.</sys:String>
    <sys:String x:Key="About.Copyright">© 2026 coldhighsun</sys:String>
    <sys:String x:Key="About.ViewOnGitHub">View on GitHub</sys:String>
    <sys:String x:Key="About.ViewWinFsp">Powered by WinFsp</sys:String>

    <!-- SaveFileDialog -->
    <sys:String x:Key="SaveDlg.Title">Select Image File</sys:String>
    <sys:String x:Key="SaveDlg.Filter">ManagedDrive Image (*.mdr)|*.mdr|All Files (*.*)|*.*</sys:String>

</ResourceDictionary>

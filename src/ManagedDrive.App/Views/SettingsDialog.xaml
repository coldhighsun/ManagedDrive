<Window x:Class="ManagedDrive.App.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Style="{StaticResource MaterialDesignWindow}"
        Title="{DynamicResource Settings.Title}"
        Width="380" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignBackground}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Run at startup -->
        <CheckBox Grid.Row="0" Grid.ColumnSpan="2"
                  x:Name="RunAtStartupBox"
                  Content="{DynamicResource Settings.RunAtStartup}"
                  ToolTip="{DynamicResource Tip.RunAtStartup}"/>

        <!-- Start minimized -->
        <CheckBox Grid.Row="2" Grid.ColumnSpan="2" Grid.Column="0"
                  x:Name="StartMinimizedBox"
                  Content="{DynamicResource Settings.StartMinimized}"
                  ToolTip="{DynamicResource Tip.StartMinimized}"/>

        <!-- Language -->
        <TextBlock Grid.Row="4" Grid.Column="0"
                   Text="{DynamicResource Settings.Language}"
                   VerticalAlignment="Center"/>
        <ComboBox Grid.Row="4" Grid.Column="1"
                  x:Name="LanguageBox"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Grid.Column="0"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn.Cancel}" Width="80" IsCancel="True"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Btn.Ok}" Width="80" IsDefault="True"
                    Click="OK_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>
        </StackPanel>
    </Grid>
</Window>

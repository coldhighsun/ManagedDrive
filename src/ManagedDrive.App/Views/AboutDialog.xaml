<views:DialogWindowBase x:Class="ManagedDrive.App.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ManagedDrive.App.Views"
        Style="{StaticResource DialogWindowStyle}"
        Title="{DynamicResource Window.Title}"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">

        <Grid Margin="4,0,4,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Icon + app name -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="pack://application:,,,/ManagedDrive.ico"
                       Width="64" Height="64"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="ManagedDrive"
                               FontSize="20" FontWeight="Medium"/>
                    <TextBlock x:Name="VersionText"
                               FontSize="12"
                               Foreground="{DynamicResource AppForegroundLight}"
                               Margin="0,2,0,0"/>
                    <TextBlock x:Name="UpdateStatusText"
                               FontSize="12"
                               Margin="0,4,0,0"
                               Visibility="Collapsed">
                        <Hyperlink x:Name="UpdateLink" RequestNavigate="Hyperlink_RequestNavigate">
                            <Run x:Name="UpdateLinkRun"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- Description + copyright + link -->
            <StackPanel Grid.Row="2" Margin="0">
                <TextBlock Text="{DynamicResource About.Description}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AppForegroundLight}"
                           LineHeight="20"
                           Margin="0,0,0,10"/>
                <TextBlock Text="{DynamicResource About.Copyright}"
                           FontSize="12"
                           Foreground="{DynamicResource AppForegroundLight}"
                           Margin="0,0,0,6"/>
                <TextBlock FontSize="12">
                    <Hyperlink x:Name="GitHubLink" RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="{DynamicResource About.ViewOnGitHub}"/>
                    </Hyperlink>
                </TextBlock>
                <TextBlock FontSize="12" Margin="0,4,0,0">
                    <Hyperlink x:Name="WinFspLink" RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="{DynamicResource About.ViewWinFsp}"/>
                    </Hyperlink>
                </TextBlock>
                <TextBlock Text="{DynamicResource About.WinFspLicense}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AppForegroundLight}"
                           Margin="0,1,0,0"/>
                <TextBlock FontSize="12" Margin="0,6,0,0">
                    <Hyperlink x:Name="SharpCompressLink" RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="{DynamicResource About.ViewSharpCompress}"/>
                    </Hyperlink>
                </TextBlock>
                <TextBlock Text="{DynamicResource About.SharpCompressLicense}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AppForegroundLight}"
                           Margin="0,1,0,0"/>
            </StackPanel>

            <!-- OK button -->
            <Button Grid.Row="4"
                    Content="{DynamicResource Btn.Ok}"
                    Width="80"
                    IsDefault="True"
                    IsCancel="True"
                    HorizontalAlignment="Right"
                    Style="{StaticResource RaisedButton}"/>
        </Grid>
</views:DialogWindowBase>

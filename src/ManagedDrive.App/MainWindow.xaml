<Window x:Class="ManagedDrive.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ManagedDrive.App.ViewModels"
        mc:Ignorable="d"
        Icon="pack://application:,,,/ManagedDrive.ico"
        Title="{DynamicResource Window.Title}"
        Height="480" Width="760"
        MinHeight="320" MinWidth="520">

    <DockPanel>

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top">
            <Button Content="{DynamicResource Btn.NewDisk}"
                    Command="{Binding CreateDiskCommand}"
                    Padding="8,2" ToolTip="{DynamicResource Tip.NewDisk}"/>
            <Separator/>
            <Button Content="{DynamicResource Btn.Unmount}"
                    Command="{Binding UnmountCommand}"
                    Padding="8,2" ToolTip="{DynamicResource Tip.Unmount}"/>
            <Button Content="{DynamicResource Btn.SaveImage}"
                    Command="{Binding SaveImageCommand}"
                    Padding="8,2" ToolTip="{DynamicResource Tip.SaveImage}"/>
            <Separator/>
            <Button Content="{DynamicResource Btn.Refresh}"
                    Command="{Binding RefreshCommand}"
                    Padding="8,2" ToolTip="{DynamicResource Tip.Refresh}"/>
            <Separator/>
            <Button Content="{DynamicResource Btn.Settings}"
                    Command="{Binding SettingsCommand}"
                    Padding="8,2" ToolTip="{DynamicResource Tip.Settings}"/>
        </ToolBar>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Disk list -->
        <DataGrid ItemsSource="{Binding Disks}"
                  SelectedItem="{Binding SelectedDisk}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  Margin="0">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColMountPoint" Header="Mount Point" Binding="{Binding MountPoint}" Width="100"/>
                <DataGridTextColumn x:Name="ColLabel"      Header="Label"       Binding="{Binding VolumeLabel}" Width="140"/>
                <DataGridTextColumn x:Name="ColCapacity"   Header="Capacity"    Binding="{Binding CapacityFormatted}" Width="90"/>
                <DataGridTextColumn x:Name="ColUsed"       Header="Used"        Binding="{Binding UsedFormatted}" Width="90"/>
                <DataGridTextColumn x:Name="ColFree"       Header="Free"        Binding="{Binding FreeFormatted}" Width="90"/>
                <DataGridTemplateColumn x:Name="ColUsage"  Header="Usage" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type vm:DiskViewModel}">
                            <ProgressBar Minimum="0" Maximum="100"
                                         Value="{Binding UsedPercent, Mode=OneWay}"
                                         Height="12" Margin="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>

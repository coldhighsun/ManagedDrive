<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AppPrimary" Color="#3F51B5"/>
    <SolidColorBrush x:Key="AppPrimaryDark" Color="#303F9F"/>
    <SolidColorBrush x:Key="AppPrimaryForeground" Color="White"/>
    <SolidColorBrush x:Key="AppForeground" Color="#DD000000"/>
    <SolidColorBrush x:Key="AppForegroundLight" Color="#89000000"/>
    <SolidColorBrush x:Key="AppBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppSurface" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppDivider" Color="#1F000000"/>
    <SolidColorBrush x:Key="AppToolBarBackground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="AppWarning" Color="#FF9800"/>
    <SolidColorBrush x:Key="AppHover" Color="#0A000000"/>
    <SolidColorBrush x:Key="AppPressed" Color="#14000000"/>
    <SolidColorBrush x:Key="AppBarBackground" Color="#3F51B5"/>
    <SolidColorBrush x:Key="AppBarForeground" Color="White"/>

</ResourceDictionary>

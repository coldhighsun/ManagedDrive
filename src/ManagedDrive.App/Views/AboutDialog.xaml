<Window x:Class="ManagedDrive.App.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindow}"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppDivider}"
            BorderThickness="1"
            CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="18" ShadowDepth="2"/>
        </Border.Effect>

        <Grid Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Icon + app name -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="pack://application:,,,/ManagedDrive.ico"
                       Width="40" Height="40"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="ManagedDrive"
                               FontSize="20" FontWeight="Medium"/>
                    <TextBlock x:Name="VersionText"
                               FontSize="12"
                               Foreground="{DynamicResource AppForegroundLight}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Description + copyright + link -->
            <StackPanel Grid.Row="2" Margin="0">
                <TextBlock Text="{DynamicResource About.Description}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AppForegroundLight}"
                           LineHeight="20"
                           Margin="0,0,0,10"/>
                <TextBlock Text="{DynamicResource About.Copyright}"
                           FontSize="12"
                           Foreground="{DynamicResource AppForegroundLight}"
                           Margin="0,0,0,6"/>
                <TextBlock FontSize="12">
                    <Hyperlink x:Name="GitHubLink" RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="{DynamicResource About.ViewOnGitHub}"/>
                    </Hyperlink>
                </TextBlock>
                <TextBlock FontSize="12" Margin="0,4,0,0">
                    <Hyperlink x:Name="WinFspLink" RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="{DynamicResource About.ViewWinFsp}"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

            <!-- OK button -->
            <Button Grid.Row="4"
                    Content="{DynamicResource Btn.Ok}"
                    Width="80"
                    IsDefault="True"
                    IsCancel="True"
                    HorizontalAlignment="Right"
                    Style="{StaticResource RaisedButton}"/>
        </Grid>
    </Border>
</Window>

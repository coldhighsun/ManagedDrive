<Window x:Class="ManagedDrive.App.Views.CreateDiskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:ManagedDrive.App.Helpers"
        Style="{StaticResource AppWindow}"
        Title="{DynamicResource CreateDisk.Title}"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Drive Letter -->
        <ComboBox Grid.Row="0" x:Name="DriveLetterBox" IsEditable="False"
                  helpers:HintHelper.Text="{DynamicResource CreateDisk.DriveLetter}"
                  Style="{StaticResource OutlinedComboBox}"/>

        <!-- Volume Label -->
        <TextBox Grid.Row="2" x:Name="VolumeLabelBox" MaxLength="32"
                 helpers:HintHelper.Text="{DynamicResource CreateDisk.VolumeLabel}"
                 Style="{StaticResource OutlinedTextBox}"/>

        <!-- Capacity -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="CapacityBox" Text="2"
                         helpers:HintHelper.Text="{DynamicResource CreateDisk.Capacity}"
                         ToolTip="{DynamicResource Tip.Capacity}"
                         Style="{StaticResource OutlinedTextBox}"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="CapacityBox_PreviewTextInput"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                    <RepeatButton x:Name="CapacityUp" Content="&#xE70E;" FontFamily="Segoe Fluent Icons"
                                  FontSize="8" Width="24" Height="16" Click="CapacityUp_Click"
                                  BorderThickness="0" Background="Transparent"/>
                    <RepeatButton x:Name="CapacityDown" Content="&#xE70D;" FontFamily="Segoe Fluent Icons"
                                  FontSize="8" Width="24" Height="16" Click="CapacityDown_Click"
                                  BorderThickness="0" Background="Transparent"/>
                </StackPanel>
            </Grid>
            <ComboBox Grid.Column="2" x:Name="CapacityUnitBox" IsEditable="False"
                      Style="{StaticResource OutlinedComboBox}"/>
        </Grid>

        <!-- Read Only -->
        <CheckBox Grid.Row="6" x:Name="ReadOnlyBox"
                  Content="{DynamicResource CreateDisk.ReadOnly}"/>

        <!-- Auto Mount -->
        <CheckBox Grid.Row="8" x:Name="AutoMountBox" IsChecked="True"
                  Content="{DynamicResource CreateDisk.AutoMount}"
                  ToolTip="{DynamicResource Tip.AutoMount}"/>

        <!-- Image Path -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ImagePathBox"
                     helpers:HintHelper.Text="{DynamicResource CreateDisk.ImageFile}"
                     ToolTip="{DynamicResource Tip.ImageFile}"
                     Style="{StaticResource OutlinedTextBox}"/>
            <Button Grid.Column="2" Content="&#xD7;" Width="40"
                    ToolTip="{DynamicResource Tip.ClearImagePath}"
                    Click="ClearImagePath_Click"
                    Style="{StaticResource OutlinedButton}"/>
            <Button Grid.Column="4" Content="&#x2026;" Width="40"
                    Click="BrowseImagePath_Click"
                    Style="{StaticResource OutlinedButton}"/>
        </Grid>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn.Cancel}" Width="80" IsCancel="True"
                    Style="{StaticResource FlatButton}"
                    Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Btn.Ok}" Width="80" IsDefault="True"
                    Click="OK_Click"
                    Style="{StaticResource RaisedButton}"/>
        </StackPanel>
    </Grid>
</Window>

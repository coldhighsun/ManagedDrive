<Window x:Class="ManagedDrive.App.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindow}"
        Title="{DynamicResource Settings.Title}"
        Width="380" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Run at startup -->
        <CheckBox Grid.Row="0" Grid.ColumnSpan="2"
                  x:Name="RunAtStartupBox"
                  Content="{DynamicResource Settings.RunAtStartup}"
                  Foreground="{DynamicResource AppForeground}"
                  ToolTip="{DynamicResource Tip.RunAtStartup}"/>

        <!-- Start minimized -->
        <CheckBox Grid.Row="2" Grid.ColumnSpan="2" Grid.Column="0"
                  x:Name="StartMinimizedBox"
                  Content="{DynamicResource Settings.StartMinimized}"
                  Foreground="{DynamicResource AppForeground}"
                  ToolTip="{DynamicResource Tip.StartMinimized}"/>

        <!-- Language -->
        <TextBlock Grid.Row="4" Grid.Column="0"
                   Text="{DynamicResource Settings.Language}"
                   VerticalAlignment="Center"/>
        <ComboBox Grid.Row="4" Grid.Column="1"
                  x:Name="LanguageBox"
                  Style="{StaticResource OutlinedComboBox}"/>

        <!-- Theme -->
        <TextBlock Grid.Row="6" Grid.Column="0"
                   Text="{DynamicResource Settings.Theme}"
                   VerticalAlignment="Center"/>
        <ComboBox Grid.Row="6" Grid.Column="1"
                  x:Name="ThemeBox"
                  Style="{StaticResource OutlinedComboBox}"/>

        <!-- High usage warning threshold -->
        <TextBlock Grid.Row="8" Grid.Column="0"
                   Text="{DynamicResource Settings.HighUsageWarnPercent}"
                   VerticalAlignment="Center"/>
        <Grid Grid.Row="8" Grid.Column="1" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="HighUsageWarnPercentBox" Text="90" MaxLength="2"
                     ToolTip="{DynamicResource Tip.HighUsageWarnPercent}"
                     Style="{StaticResource OutlinedTextBox}"
                     VerticalContentAlignment="Center"
                     TextAlignment="Right"
                     PreviewTextInput="PercentBox_PreviewTextInput"
                     TextChanged="PercentBox_TextChanged"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                <RepeatButton x:Name="HighUsageWarnPercentUp" Content="&#xE70E;" FontFamily="Segoe Fluent Icons"
                              FontSize="8" Width="24" Height="16" Click="HighUsageWarnPercentUp_Click"
                              Style="{StaticResource SpinRepeatButton}"/>
                <RepeatButton x:Name="HighUsageWarnPercentDown" Content="&#xE70D;" FontFamily="Segoe Fluent Icons"
                              FontSize="8" Width="24" Height="16" Click="HighUsageWarnPercentDown_Click"
                              Style="{StaticResource SpinRepeatButton}"/>
            </StackPanel>
        </Grid>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Grid.Column="0"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn.Cancel}" Width="80" IsCancel="True"
                    Style="{StaticResource FlatButton}"
                    Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Btn.Ok}" Width="80" IsDefault="True"
                    Click="OK_Click"
                    Style="{StaticResource RaisedButton}"/>
        </StackPanel>
    </Grid>
</Window>

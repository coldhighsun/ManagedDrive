<?xml version="1.0" encoding="utf-8"?>
<WixLocalization xmlns="http://wixtoolset.org/schemas/v4/wxl" Culture="zh-CN">
  <String Id="LicenseRtfPath" Value="installer\License.zh-CN.rtf" />
  <String Id="TempDirWarningTitle" Value="继续之前请检查临时目录" />
  <String Id="TempDirWarningDescription" Value="在修复或卸载之前，请仔细阅读以下内容。" />
  <String Id="TempDirWarningHeading" Value="重要提示：请确保临时目录未指向内存盘" />
  <String Id="TempDirWarningBody" Value="如果您的 Windows 用户临时目录（TEMP / TMP）当前指向 ManagedDrive 内存盘，修复或卸载操作可能会失败，因为安装程序本身需要向临时目录写入文件。&#13;&#10;&#13;&#10;继续之前，请打开 ManagedDrive，使用主界面中临时目录指示器旁边的「恢复默认用户临时文件夹」功能，将临时目录恢复为 Windows 默认值。&#13;&#10;&#13;&#10;如果 ManagedDrive 未在运行，可手动重置：打开「系统属性」→「高级」→「环境变量」，将 TEMP 和 TMP 设置回 %USERPROFILE%\AppData\Local\Temp。" />
  <String Id="TempDirWarningContinue" Value="我已了解，继续(&amp;C)" />
</WixLocalization>

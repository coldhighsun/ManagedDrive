<Window x:Class="ManagedDrive.App.Views.CreateDiskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindow}"
        Title="{DynamicResource CreateDisk.Title}"
        Width="440" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" x:Name="MainTabControl" Style="{StaticResource AppTabControl}" MinHeight="360">

            <!-- Basic Info -->
            <TabItem Header="{DynamicResource CreateDisk.Section.Basic}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Drive Letter -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource CreateDisk.DriveLetter}"
                                   Foreground="{DynamicResource AppForeground}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="2" x:Name="DriveLetterBox" IsEditable="False"
                                  Style="{StaticResource OutlinedComboBox}"/>
                    </Grid>

                    <!-- Capacity -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource CreateDisk.Capacity}"
                                   Foreground="{DynamicResource AppForeground}"
                                   VerticalAlignment="Center"/>
                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CapacityBox" Text="2"
                                     ToolTip="{DynamicResource Tip.Capacity}"
                                     Style="{StaticResource OutlinedTextBox}"
                                     VerticalContentAlignment="Center"
                                     HorizontalContentAlignment="Right"
                                     PreviewTextInput="CapacityBox_PreviewTextInput"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                                <RepeatButton x:Name="CapacityUp" Content="&#xE70E;" FontFamily="Segoe Fluent Icons"
                                              FontSize="8" Width="24" Height="16" Click="CapacityUp_Click"
                                              Style="{StaticResource SpinRepeatButton}"/>
                                <RepeatButton x:Name="CapacityDown" Content="&#xE70D;" FontFamily="Segoe Fluent Icons"
                                              FontSize="8" Width="24" Height="16" Click="CapacityDown_Click"
                                              Style="{StaticResource SpinRepeatButton}"/>
                            </StackPanel>
                        </Grid>
                        <ComboBox Grid.Column="4" x:Name="CapacityUnitBox" IsEditable="False"
                                  Style="{StaticResource OutlinedComboBox}"/>
                    </Grid>

                    <!-- Volume Label -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource CreateDisk.VolumeLabel}"
                                   Foreground="{DynamicResource AppForeground}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" x:Name="VolumeLabelBox" MaxLength="32"
                                 Style="{StaticResource OutlinedTextBox}"/>
                    </Grid>

                    <!-- High Usage Warning -->
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="HighUsageWarnBox" IsChecked="True"
                                  Content="{DynamicResource CreateDisk.HighUsageWarn}"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource AppForeground}"
                                  ToolTip="{DynamicResource Tip.HighUsageWarn}"
                                  Checked="HighUsageWarnBox_CheckedChanged" Unchecked="HighUsageWarnBox_CheckedChanged"/>
                        <Grid Grid.Column="2" x:Name="HighUsageWarnPercentPanel" IsEnabled="False" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="HighUsageWarnPercentBox" Text="90" MaxLength="2"
                                     ToolTip="{DynamicResource Tip.HighUsageWarn}"
                                     Style="{StaticResource OutlinedTextBox}"
                                     VerticalContentAlignment="Center"
                                     TextAlignment="Right"
                                     PreviewTextInput="CapacityBox_PreviewTextInput"/>
                            <TextBlock Grid.Column="1" Text="%"
                                       Foreground="{DynamicResource AppForeground}"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </Grid>
                    </Grid>

                    <!-- Auto Mount -->
                    <CheckBox Grid.Row="8" x:Name="AutoMountBox" IsChecked="True"
                              Content="{DynamicResource CreateDisk.AutoMount}"
                              Foreground="{DynamicResource AppForeground}"
                              ToolTip="{DynamicResource Tip.AutoMount}"/>

                    <!-- Read Only -->
                    <CheckBox Grid.Row="10" x:Name="ReadOnlyBox"
                              Content="{DynamicResource CreateDisk.ReadOnly}"
                              Foreground="{DynamicResource AppForeground}"
                              ToolTip="{DynamicResource Tip.ReadOnly}"
                              Checked="ReadOnlyBox_CheckedChanged" Unchecked="ReadOnlyBox_CheckedChanged"/>
                </Grid>
            </TabItem>

            <!-- Persistence -->
            <TabItem Header="{DynamicResource CreateDisk.Section.Persistence}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Image Path -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource CreateDisk.ImageFile}"
                                   Foreground="{DynamicResource AppForeground}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" x:Name="ImagePathBox" IsReadOnly="True" Cursor="Hand"
                                 ToolTip="{DynamicResource Tip.ImageFile}"
                                 Style="{StaticResource OutlinedTextBox}"
                                 PreviewMouseLeftButtonDown="ImagePathBox_PreviewMouseLeftButtonDown"/>
                        <Button Grid.Column="4" x:Name="ClearImagePathButton" Content="&#xD7;" Width="40"
                                ToolTip="{DynamicResource Tip.ClearImagePath}"
                                Click="ClearImagePath_Click"
                                Style="{StaticResource OutlinedButton}"/>
                    </Grid>

                    <!-- Import Note -->
                    <TextBlock Grid.Row="1" x:Name="ImportNoteText"
                               Text="{DynamicResource CreateDisk.ImportNote}"
                               Foreground="{DynamicResource AppForegroundLight}"
                               FontSize="11" TextWrapping="Wrap" Margin="92,4,0,0"
                               Visibility="Collapsed"/>

                    <!-- Compression Level -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource CreateDisk.CompressionLevel}"
                                   Foreground="{DynamicResource AppForeground}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="2" x:Name="CompressionLevelBox" IsEditable="False"
                                  ToolTip="{DynamicResource Tip.CompressionLevel}"
                                  Style="{StaticResource OutlinedComboBox}"
                                  SelectionChanged="CompressionLevelBox_SelectionChanged"/>
                    </Grid>

                    <!-- Compression Warning -->
                    <TextBlock Grid.Row="4" x:Name="CompressionWarningText"
                               Text="{DynamicResource CreateDisk.CompressionWarning}"
                               Foreground="{DynamicResource AppWarning}"
                               FontSize="11" TextWrapping="Wrap" Margin="92,4,0,0"
                               Visibility="Collapsed"/>

                    <!-- Section divider: image/compression above, auto-save/snapshots below -->
                    <Border Grid.Row="5" BorderBrush="{DynamicResource AppDivider}" BorderThickness="0,1,0,0"
                            VerticalAlignment="Center"/>

                    <!-- Auto Save -->
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="AutoSaveBox" VerticalAlignment="Center"
                                  Content="{DynamicResource CreateDisk.AutoSave}"
                                  Foreground="{DynamicResource AppForeground}"
                                  ToolTip="{DynamicResource Tip.AutoSave}"
                                  Checked="AutoSaveBox_CheckedChanged" Unchecked="AutoSaveBox_CheckedChanged"/>
                        <Grid Grid.Column="2" x:Name="AutoSaveIntervalPanel" IsEnabled="False" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AutoSaveIntervalBox" Text="10" MaxLength="2"
                                     ToolTip="{DynamicResource Tip.AutoSaveInterval}"
                                     Style="{StaticResource OutlinedTextBox}"
                                     VerticalContentAlignment="Center"
                                     PreviewTextInput="CapacityBox_PreviewTextInput"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                                <RepeatButton x:Name="AutoSaveIntervalUp" Content="&#xE70E;" FontFamily="Segoe Fluent Icons"
                                              FontSize="8" Width="24" Height="16" Click="AutoSaveIntervalUp_Click"
                                              Style="{StaticResource SpinRepeatButton}"/>
                                <RepeatButton x:Name="AutoSaveIntervalDown" Content="&#xE70D;" FontFamily="Segoe Fluent Icons"
                                              FontSize="8" Width="24" Height="16" Click="AutoSaveIntervalDown_Click"
                                              Style="{StaticResource SpinRepeatButton}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- Snapshot Explanation -->
                    <TextBlock Grid.Row="8" Text="{DynamicResource CreateDisk.SnapshotExplanation}"
                               Foreground="{DynamicResource AppForegroundLight}"
                               FontSize="11" TextWrapping="Wrap"/>

                    <!-- Snapshot Max Count -->
                    <Grid Grid.Row="10" Margin="16,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="SnapshotCountEnabledBox" VerticalAlignment="Center"
                                  Content="{DynamicResource CreateDisk.SnapshotMaxCount}"
                                  Foreground="{DynamicResource AppForeground}"
                                  ToolTip="{DynamicResource Tip.SnapshotMaxCount}"
                                  Checked="SnapshotLimit_CheckedChanged" Unchecked="SnapshotLimit_CheckedChanged"/>
                        <Grid Grid.Column="2" x:Name="SnapshotCountPanel" IsEnabled="False" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SnapshotCountBox" Text="10" MaxLength="3"
                                     Style="{StaticResource OutlinedTextBox}"
                                     VerticalContentAlignment="Center"
                                     PreviewTextInput="CapacityBox_PreviewTextInput"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                                <RepeatButton x:Name="SnapshotCountUp" Content="&#xE70E;" FontFamily="Segoe Fluent Icons"
                                              FontSize="8" Width="24" Height="16" Click="SnapshotCountUp_Click"
                                              Style="{StaticResource SpinRepeatButton}"/>
                                <RepeatButton x:Name="SnapshotCountDown" Content="&#xE70D;" FontFamily="Segoe Fluent Icons"
                                              FontSize="8" Width="24" Height="16" Click="SnapshotCountDown_Click"
                                              Style="{StaticResource SpinRepeatButton}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- Snapshot Max Size -->
                    <Grid Grid.Row="12" Margin="16,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="SnapshotSizeEnabledBox" VerticalAlignment="Center"
                                  Content="{DynamicResource CreateDisk.SnapshotMaxSize}"
                                  Foreground="{DynamicResource AppForeground}"
                                  ToolTip="{DynamicResource Tip.SnapshotMaxSize}"
                                  Checked="SnapshotLimit_CheckedChanged" Unchecked="SnapshotLimit_CheckedChanged"/>
                        <Grid Grid.Column="2" x:Name="SnapshotSizePanel" IsEnabled="False" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SnapshotSizeBox" Text="500" MaxLength="6"
                                     Style="{StaticResource OutlinedTextBox}"
                                     VerticalContentAlignment="Center"
                                     PreviewTextInput="CapacityBox_PreviewTextInput"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                                <RepeatButton x:Name="SnapshotSizeUp" Content="&#xE70E;" FontFamily="Segoe Fluent Icons"
                                              FontSize="8" Width="24" Height="16" Click="SnapshotSizeUp_Click"
                                              Style="{StaticResource SpinRepeatButton}"/>
                                <RepeatButton x:Name="SnapshotSizeDown" Content="&#xE70D;" FontFamily="Segoe Fluent Icons"
                                              FontSize="8" Width="24" Height="16" Click="SnapshotSizeDown_Click"
                                              Style="{StaticResource SpinRepeatButton}"/>
                            </StackPanel>
                        </Grid>
                        <ComboBox Grid.Column="4" x:Name="SnapshotSizeUnitBox" IsEnabled="False" IsEditable="False"
                                  Style="{StaticResource OutlinedComboBox}"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn.Cancel}" Width="80" IsCancel="True"
                    Style="{StaticResource FlatButton}"
                    Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Btn.Ok}" Width="80" IsDefault="True"
                    Click="OK_Click"
                    Style="{StaticResource RaisedButton}"/>
        </StackPanel>
    </Grid>
</Window>

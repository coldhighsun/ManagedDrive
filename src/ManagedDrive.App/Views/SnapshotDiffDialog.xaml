<views:DialogWindowBase x:Class="ManagedDrive.App.Views.SnapshotDiffDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ManagedDrive.App.Views"
        Style="{StaticResource DialogWindowStyle}"
        Title="{DynamicResource SnapshotDiff.Title}"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="SourceDescriptionText"
                   Foreground="{DynamicResource AppForegroundLight}"
                   TextWrapping="Wrap"/>

        <TextBlock Grid.Row="2"
                   x:Name="SummaryText"
                   Foreground="{DynamicResource AppForegroundLight}"
                   FontSize="11"
                   TextWrapping="Wrap"/>

        <Border Grid.Row="4" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <TextBlock x:Name="NoChangesText"
                           Text="{DynamicResource SnapshotDiff.NoChanges}"
                           Foreground="{DynamicResource AppForegroundLight}"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>

                <TreeView x:Name="ChangesTree" MaxHeight="320"
                          BorderThickness="0" Background="Transparent"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingStackPanel.IsVirtualizing="True">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type views:DiffGroup}" ItemsSource="{Binding Nodes}">
                            <TextBlock Text="{Binding Header}" FontWeight="Medium"
                                       Foreground="{DynamicResource AppForeground}"/>
                        </HierarchicalDataTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type views:DiffNode}" ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource AppForegroundLight}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                            <Setter Property="Foreground" Value="{DynamicResource AppForeground}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </StackPanel>
        </Border>

        <!-- Close -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn.Close}" Width="80" IsDefault="True" IsCancel="True"
                    Style="{StaticResource RaisedButton}"/>
        </StackPanel>
    </Grid>
</views:DialogWindowBase>

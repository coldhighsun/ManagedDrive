<Window x:Class="ManagedDrive.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ManagedDrive – RAM Disk Manager"
        Height="480" Width="760"
        MinHeight="320" MinWidth="520"
        Closing="Window_Closing">

    <DockPanel>

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top">
            <Button Content="🖴  New Disk"
                    Command="{Binding CreateDiskCommand}"
                    Padding="8,2" ToolTip="Create and mount a new RAM disk"/>
            <Separator/>
            <Button Content="⏏  Unmount"
                    Command="{Binding UnmountCommand}"
                    Padding="8,2" ToolTip="Unmount the selected disk"/>
            <Button Content="💾  Save Image"
                    Command="{Binding SaveImageCommand}"
                    Padding="8,2" ToolTip="Save the selected disk's contents to its image file"/>
            <Separator/>
            <Button Content="↻  Refresh"
                    Command="{Binding RefreshCommand}"
                    Padding="8,2" ToolTip="Refresh usage statistics"/>
            <Separator/>
            <Button Content="⚙  Settings"
                    Command="{Binding SettingsCommand}"
                    Padding="8,2" ToolTip="Application settings"/>
        </ToolBar>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Disk list -->
        <DataGrid ItemsSource="{Binding Disks}"
                  SelectedItem="{Binding SelectedDisk}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  Margin="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mount Point" Binding="{Binding MountPoint}" Width="100"/>
                <DataGridTextColumn Header="Label"       Binding="{Binding VolumeLabel}" Width="140"/>
                <DataGridTextColumn Header="Capacity"    Binding="{Binding CapacityFormatted}" Width="90"/>
                <DataGridTextColumn Header="Used"        Binding="{Binding UsedFormatted}" Width="90"/>
                <DataGridTextColumn Header="Free"        Binding="{Binding FreeFormatted}" Width="90"/>
                <DataGridTemplateColumn Header="Usage" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ProgressBar Minimum="0" Maximum="100"
                                         Value="{Binding UsedPercent, Mode=OneWay}"
                                         Height="12" Margin="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>

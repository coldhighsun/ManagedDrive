<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- MainWindow -->
    <sys:String x:Key="Window.Title">ManagedDrive – RAM 虚拟磁盘管理器</sys:String>
    <sys:String x:Key="Menu.File">文件(_F)</sys:String>
    <sys:String x:Key="Menu.Tools">工具(_T)</sys:String>
    <sys:String x:Key="Menu.Exit">退出(_X)</sys:String>
    <sys:String x:Key="Btn.NewDisk">新建磁盘</sys:String>
    <sys:String x:Key="Btn.OpenInExplorer">在资源管理器中打开</sys:String>
    <sys:String x:Key="Btn.Unmount">卸载</sys:String>
    <sys:String x:Key="Btn.SaveImage">保存镜像</sys:String>
    <sys:String x:Key="Btn.Refresh">刷新</sys:String>
    <sys:String x:Key="Btn.Settings">设置</sys:String>
    <sys:String x:Key="Tip.NewDisk">创建并挂载新的 RAM 磁盘</sys:String>
    <sys:String x:Key="Tip.Unmount">卸载所选磁盘</sys:String>
    <sys:String x:Key="Tip.SaveImage">将所选磁盘内容保存到镜像文件</sys:String>
    <sys:String x:Key="Tip.Refresh">刷新使用情况统计</sys:String>
    <sys:String x:Key="Tip.Settings">应用程序设置</sys:String>
    <sys:String x:Key="Tip.Minimize">最小化</sys:String>
    <sys:String x:Key="Tip.Close">最小化到系统托盘</sys:String>
    <sys:String x:Key="Col.MountPoint">挂载点</sys:String>
    <sys:String x:Key="Col.Label">卷标</sys:String>
    <sys:String x:Key="Col.Capacity">容量</sys:String>
    <sys:String x:Key="Col.Used">已用</sys:String>
    <sys:String x:Key="Col.Free">可用</sys:String>
    <sys:String x:Key="Col.Usage">使用率</sys:String>

    <!-- CreateDiskDialog -->
    <sys:String x:Key="CreateDisk.Title">创建 RAM 磁盘</sys:String>
    <sys:String x:Key="CreateDisk.DriveLetter">驱动器号：</sys:String>
    <sys:String x:Key="CreateDisk.VolumeLabel">卷标：</sys:String>
    <sys:String x:Key="CreateDisk.Capacity">容量：</sys:String>
    <sys:String x:Key="CreateDisk.ReadOnly">只读</sys:String>
    <sys:String x:Key="CreateDisk.AutoMount">自动挂载</sys:String>
    <sys:String x:Key="CreateDisk.ImageFile">镜像文件</sys:String>
    <sys:String x:Key="CreateDisk.DefaultLabel">RAM 磁盘</sys:String>
    <sys:String x:Key="Tip.Capacity">磁盘大小（选择单位：MB 或 GB）</sys:String>
    <sys:String x:Key="Tip.AutoMount">下次启动时自动重新挂载此磁盘</sys:String>
    <sys:String x:Key="Tip.ImageFile">可选：.mdr 镜像文件路径，用于持久化存储（留空则为临时磁盘）</sys:String>

    <!-- SettingsDialog -->
    <sys:String x:Key="Settings.Title">设置</sys:String>
    <sys:String x:Key="Settings.RunAtStartup">开机自动启动</sys:String>
    <sys:String x:Key="Settings.StartMinimized">启动时最小化到托盘</sys:String>
    <sys:String x:Key="Settings.Language">语言</sys:String>
    <sys:String x:Key="Lang.System">系统默认</sys:String>
    <sys:String x:Key="Tip.RunAtStartup">Windows 启动时自动运行 ManagedDrive</sys:String>
    <sys:String x:Key="Tip.StartMinimized">启动时隐藏主窗口，仅显示系统托盘图标</sys:String>

    <!-- Shared buttons -->
    <sys:String x:Key="Btn.Ok">_确定</sys:String>
    <sys:String x:Key="Btn.Cancel">_取消</sys:String>

    <!-- Tray menu -->
    <sys:String x:Key="Tray.Show">显示</sys:String>
    <sys:String x:Key="Tray.NewDisk">新建磁盘</sys:String>
    <sys:String x:Key="Tray.Exit">退出</sys:String>
    <sys:String x:Key="Tray.NoDisksMounted">暂无已挂载的磁盘</sys:String>
    <sys:String x:Key="Tray.HighUsageTitle">RAM 磁盘空间不足</sys:String>
    <sys:String x:Key="Tray.HighUsageBody">{0}（{1}）已使用 {2:F0}%。</sys:String>

    <!-- Status bar -->
    <sys:String x:Key="Status.Ready">就绪。</sys:String>
    <sys:String x:Key="Status.Mounted">已挂载 {0}（{1}）。</sys:String>
    <sys:String x:Key="Status.MountedWithCapacity">已挂载 {0}（{1}，{2} MB）。</sys:String>
    <sys:String x:Key="Status.AutoMountFailed">自动挂载"{0}"失败：{1}</sys:String>
    <sys:String x:Key="Status.MountFailed">挂载失败。</sys:String>
    <sys:String x:Key="Status.ImageSaved">已保存 {0} 的镜像。</sys:String>
    <sys:String x:Key="Status.Unmounted">已卸载 {0}。</sys:String>

    <!-- MessageBox bodies -->
    <sys:String x:Key="Msg.AlreadyRunning">ManagedDrive 已在运行。</sys:String>
    <sys:String x:Key="Msg.WinFspMissingTitle">ManagedDrive – 缺少必要组件</sys:String>
    <sys:String x:Key="Msg.WinFspMissingBody">此程序需要 WinFsp 2.1.x，但未在系统中检测到。&#x0a;&#x0a;点击「是」跳转下载页面，点击「否」退出。</sys:String>
    <sys:String x:Key="Msg.ExitConfirmTitle">ManagedDrive</sys:String>
    <sys:String x:Key="Msg.ExitConfirmBody">所有已挂载的 RAM 磁盘将被卸载，其中未挂载镜像的数据将丢失。&#x0a;&#x0a;确认退出？</sys:String>
    <sys:String x:Key="Msg.MountFailed">挂载磁盘失败：&#x0a;{0}</sys:String>
    <sys:String x:Key="Msg.SaveImageFailed">保存镜像失败：&#x0a;{0}</sys:String>

    <!-- Validation -->
    <sys:String x:Key="Val.Title">输入无效</sys:String>
    <sys:String x:Key="Val.NoDriveLetter">请选择驱动器号。</sys:String>
    <sys:String x:Key="Val.BadCapacity">容量必须在 1 到 {0} {1} 之间。</sys:String>

    <!-- SaveFileDialog -->
    <sys:String x:Key="SaveDlg.Title">选择镜像文件</sys:String>
    <sys:String x:Key="SaveDlg.Filter">ManagedDrive 镜像 (*.mdr)|*.mdr|所有文件 (*.*)|*.*</sys:String>

</ResourceDictionary>

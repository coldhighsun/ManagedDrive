<Window x:Class="ManagedDrive.App.Views.CreateDiskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource CreateDisk.Title}"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Drive Letter -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource CreateDisk.DriveLetter}" VerticalAlignment="Center"/>
        <ComboBox  Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                   x:Name="DriveLetterBox" IsEditable="False"/>

        <!-- Volume Label -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource CreateDisk.VolumeLabel}" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                   x:Name="VolumeLabelBox" MaxLength="32"/>

        <!-- Capacity -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource CreateDisk.Capacity}" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                   x:Name="CapacityBox" Text="256"
                   ToolTip="{DynamicResource Tip.Capacity}"/>

        <!-- Read Only -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource CreateDisk.ReadOnly}" VerticalAlignment="Center"/>
        <CheckBox  Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3"
                   x:Name="ReadOnlyBox" VerticalAlignment="Center"/>

        <!-- Auto Mount -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="{DynamicResource CreateDisk.AutoMount}" VerticalAlignment="Center"/>
        <CheckBox  Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="3"
                   x:Name="AutoMountBox" IsChecked="True" VerticalAlignment="Center"
                   ToolTip="{DynamicResource Tip.AutoMount}"/>

        <!-- Persist Image Path -->
        <TextBlock Grid.Row="10" Grid.Column="0" Text="{DynamicResource CreateDisk.ImageFile}" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="10" Grid.Column="1"
                   x:Name="ImagePathBox"
                   ToolTip="{DynamicResource Tip.ImageFile}"/>
        <Button    Grid.Row="10" Grid.Column="3" Content="…" Width="28"
                   Click="BrowseImagePath_Click"/>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="4"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn.Ok}"     Width="80" IsDefault="True"  Click="OK_Click"     Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Btn.Cancel}" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>

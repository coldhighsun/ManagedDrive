<Window x:Class="ManagedDrive.App.Views.CreateDiskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Style="{StaticResource MaterialDesignWindow}"
        Title="{DynamicResource CreateDisk.Title}"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignBackground}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Drive Letter -->
        <ComboBox Grid.Row="0" x:Name="DriveLetterBox" IsEditable="False"
                  materialDesign:HintAssist.Hint="{DynamicResource CreateDisk.DriveLetter}"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

        <!-- Volume Label -->
        <TextBox Grid.Row="2" x:Name="VolumeLabelBox" MaxLength="32"
                 materialDesign:HintAssist.Hint="{DynamicResource CreateDisk.VolumeLabel}"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

        <!-- Capacity -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <materialDesign:NumericUpDown x:Name="CapacityBox"
                     Value="2" Minimum="1" ValueStep="1"
                     materialDesign:HintAssist.Hint="{DynamicResource CreateDisk.Capacity}"
                     ToolTip="{DynamicResource Tip.Capacity}"
                     Style="{StaticResource MaterialDesignOutlinedNumericUpDown}"/>
            <ComboBox Grid.Column="2" x:Name="CapacityUnitBox" IsEditable="False"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
        </Grid>

        <!-- Read Only -->
        <CheckBox Grid.Row="6" x:Name="ReadOnlyBox"
                  Content="{DynamicResource CreateDisk.ReadOnly}"/>

        <!-- Auto Mount -->
        <CheckBox Grid.Row="8" x:Name="AutoMountBox" IsChecked="True"
                  Content="{DynamicResource CreateDisk.AutoMount}"
                  ToolTip="{DynamicResource Tip.AutoMount}"/>

        <!-- Image Path -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ImagePathBox"
                     materialDesign:HintAssist.Hint="{DynamicResource CreateDisk.ImageFile}"
                     ToolTip="{DynamicResource Tip.ImageFile}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <Button Grid.Column="2" Content="×" Width="40"
                    ToolTip="{DynamicResource Tip.ClearImagePath}"
                    Click="ClearImagePath_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
            <Button Grid.Column="4" Content="…" Width="40"
                    Click="BrowseImagePath_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
        </Grid>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn.Cancel}" Width="80" IsCancel="True"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Btn.Ok}" Width="80" IsDefault="True"
                    Click="OK_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>
        </StackPanel>
    </Grid>
</Window>

<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4 installer for ManagedDrive.
  Build command (from repo root):
    wix build installer/ManagedDrive.wxs
        -arch x64
        -ext WixToolset.UI.wixext
        -ext WixToolset.Util.wixext
        -d "PublishDir=publish\"
        -d "ProductVersion=1.0.0"
        -o ManagedDrive-v1.0.0-win-x64.msi

  Variables injected at build time:
    PublishDir      — path to the dotnet publish output folder (trailing backslash required)
    ProductVersion  — semver string derived from the git tag, e.g. 1.2.3
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">


  <Package
    Name="ManagedDrive"
    Manufacturer="ManagedDrive"
    Version="$(ProductVersion)"
    UpgradeCode="4A7E1234-BEEF-4C9D-A012-000000000001"
    Scope="perMachine">

    <!-- Allow in-place upgrades; remove older versions automatically -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of ManagedDrive is already installed." />

    <!-- Standard WiX UI with install-dir picker (requires WixToolset.UI.wixext) -->
    <ui:WixUI Id="WixUI_InstallDir" />
    <!-- UIRef forces the TempDirWarning fragment to be linked into the MSI -->
    <UIRef Id="TempDirWarningUI" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="!(loc.LicenseRtfPath)" />

    <Property Id="WixShellExecTarget" Value="[#ManagedDriveExe]" />
    <CustomAction Id="LaunchApplication" BinaryRef="Wix4UtilCA_X64" DllEntry="WixShellExec" Impersonate="yes" />

    <UI>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApplication" Order="1" Condition="NOT REMOVE" />
    </UI>

    <MediaTemplate EmbedCab="yes" />

    <!-- Close any running instance before file operations begin on install/upgrade/uninstall -->
    <util:CloseApplication
      Id="CloseRunningManagedDrive"
      Target="ManagedDrive.exe"
      CloseMessage="yes"
      RebootPrompt="no"
      TerminateProcess="5" />

    <Feature Id="ProductFeature" Title="ManagedDrive" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>


  </Package>

  <!-- Installation directory: C:\Program Files\ManagedDrive -->
  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="ManagedDrive" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="ManagedDrive" />
    </StandardDirectory>
  </Fragment>

  <!-- Files from the publish output directory -->
  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <!-- Main executable -->
      <Component Id="MainExecutable">
        <File Id="ManagedDriveExe"
              Source="$(PublishDir)ManagedDrive.exe"
              KeyPath="yes" />
      </Component>

      <!-- App assembly & runtime config -->
      <Component Id="ManagedDriveDll">
        <File Source="$(PublishDir)ManagedDrive.dll" KeyPath="yes" />
      </Component>
      <Component Id="ManagedDriveCore">
        <File Source="$(PublishDir)ManagedDrive.Core.dll" KeyPath="yes" />
      </Component>
      <Component Id="DepsJson">
        <File Source="$(PublishDir)ManagedDrive.deps.json" KeyPath="yes" />
      </Component>
      <Component Id="RuntimeConfig">
        <File Source="$(PublishDir)ManagedDrive.runtimeconfig.json" KeyPath="yes" />
      </Component>

      <!-- WinFsp managed assembly -->
      <Component Id="WinFspMsil">
        <File Source="$(PublishDir)winfsp-msil.dll" KeyPath="yes" />
      </Component>


      <!-- Serilog -->
      <Component Id="Serilog">
        <File Source="$(PublishDir)Serilog.dll" KeyPath="yes" />
      </Component>
      <Component Id="SerilogSinksFile">
        <File Source="$(PublishDir)Serilog.Sinks.File.dll" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Warning dialog shown before MaintenanceTypeDlg (repair/remove).
       The UI Id="TempDirWarningUI" is referenced via <UIRef> in <Package> so this fragment is linked.
       Order="3" on the MaintenanceWelcomeDlg Next override fires after the built-in publish (Order=1),
       so our NewDialog value wins. -->
  <Fragment>
    <UI Id="TempDirWarningUI">
      <Dialog Id="TempDirWarningDlg" Width="370" Height="270" Title="[ProductName] Setup">

        <!-- Top banner -->
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44"
                 TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <Control Id="Title" Type="Text" X="15" Y="8" Width="340" Height="15" Transparent="yes" NoPrefix="yes">
          <Text Value="{\WixUI_Font_Title}!(loc.TempDirWarningTitle)" />
        </Control>
        <Control Id="Description" Type="Text" X="25" Y="23" Width="330" Height="15" Transparent="yes" NoPrefix="yes">
          <Text Value="!(loc.TempDirWarningDescription)" />
        </Control>

        <!-- Body -->
        <Control Id="WarningHeading" Type="Text" X="15" Y="55" Width="340" Height="16" Transparent="yes" NoPrefix="yes">
          <Text Value="{\WixUI_Font_Bold}!(loc.TempDirWarningHeading)" />
        </Control>

        <Control Id="WarningBody" Type="Text" X="15" Y="76" Width="340" Height="148" Transparent="yes" NoPrefix="yes">
          <Text Value="!(loc.TempDirWarningBody)" />
        </Control>

        <!-- Bottom rule and buttons -->
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <!-- Back: 130+56=186  Next: 190+110=300  Cancel: 304+56=360  (all fit within 370px) -->
        <Control Id="Back" Type="PushButton" X="130" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
        <Control Id="Next" Type="PushButton" X="190" Y="243" Width="110" Height="17" Default="yes"
                 Text="!(loc.TempDirWarningContinue)" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)" />

      </Dialog>

      <!-- Wire up navigation: insert TempDirWarningDlg between MaintenanceWelcomeDlg and MaintenanceTypeDlg -->
      <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="TempDirWarningDlg" Order="3" />
      <Publish Dialog="TempDirWarningDlg" Control="Next" Event="NewDialog" Value="MaintenanceTypeDlg" />
      <Publish Dialog="TempDirWarningDlg" Control="Back" Event="NewDialog" Value="MaintenanceWelcomeDlg" />
      <Publish Dialog="TempDirWarningDlg" Control="Cancel" Event="SpawnDialog" Value="CancelDlg" />

    </UI>
  </Fragment>

  <!-- Start-menu shortcut -->
  <Fragment>
    <Icon Id="AppIcon.ico" SourceFile="$(PublishDir)ManagedDrive.exe" />

    <Component Id="ApplicationShortcut" Directory="ApplicationProgramsFolder">
      <Shortcut Id="AppStartMenuShortcut"
                Name="ManagedDrive"
                Description="ManagedDrive RAM disk manager"
                Target="[INSTALLFOLDER]ManagedDrive.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon.ico" />
      <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\ManagedDrive"
                     Name="installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>
  </Fragment>


</Wix>

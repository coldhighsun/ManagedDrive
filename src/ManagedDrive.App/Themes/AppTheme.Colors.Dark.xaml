<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AppPrimary" Color="#5C6BC0"/>
    <SolidColorBrush x:Key="AppPrimaryDark" Color="#3F51B5"/>
    <SolidColorBrush x:Key="AppPrimaryForeground" Color="White"/>
    <SolidColorBrush x:Key="AppForeground" Color="#DDFFFFFF"/>
    <SolidColorBrush x:Key="AppForegroundLight" Color="#89FFFFFF"/>
    <SolidColorBrush x:Key="AppBackground" Color="#FF1E1E1E"/>
    <SolidColorBrush x:Key="AppSurface" Color="#FF2A2A2A"/>
    <SolidColorBrush x:Key="AppDivider" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="AppToolBarBackground" Color="#FF2D2D2D"/>
    <SolidColorBrush x:Key="AppWarning" Color="#FFB74D"/>
    <SolidColorBrush x:Key="AppHover" Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="AppPressed" Color="#1FFFFFFF"/>
    <SolidColorBrush x:Key="AppBarBackground" Color="#FF2D2D2D"/>
    <SolidColorBrush x:Key="AppBarForeground" Color="#DDFFFFFF"/>

</ResourceDictionary>

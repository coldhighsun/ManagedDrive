<views:DialogWindowBase x:Class="ManagedDrive.App.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ManagedDrive.App.Views"
        Style="{StaticResource DialogWindowStyle}"
        Title="{DynamicResource Settings.Title}"
        Width="340" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Run at startup -->
        <CheckBox Grid.Row="0" Grid.ColumnSpan="2"
                  x:Name="RunAtStartupBox"
                  Content="{DynamicResource Settings.RunAtStartup}"
                  Foreground="{DynamicResource AppForeground}"
                  ToolTip="{DynamicResource Tip.RunAtStartup}"/>

        <!-- Start minimized -->
        <CheckBox Grid.Row="2" Grid.ColumnSpan="2" Grid.Column="0"
                  x:Name="StartMinimizedBox"
                  Content="{DynamicResource Settings.StartMinimized}"
                  Foreground="{DynamicResource AppForeground}"
                  ToolTip="{DynamicResource Tip.StartMinimized}"/>

        <!-- Explorer context menu for archives -->
        <CheckBox Grid.Row="4" Grid.ColumnSpan="2" Grid.Column="0"
                  x:Name="ContextMenuEnabledBox"
                  Foreground="{DynamicResource AppForeground}"
                  ToolTip="{DynamicResource Tip.ContextMenuEnabled}">
            <TextBlock Text="{DynamicResource Settings.ContextMenuEnabled}"
                       TextWrapping="Wrap"/>
        </CheckBox>

        <!-- Language -->
        <TextBlock Grid.Row="6" Grid.Column="0"
                   Text="{DynamicResource Settings.Language}"
                   VerticalAlignment="Center"/>
        <ComboBox Grid.Row="6" Grid.Column="1"
                  x:Name="LanguageBox"
                  Style="{StaticResource OutlinedComboBox}"/>

        <!-- Theme -->
        <TextBlock Grid.Row="8" Grid.Column="0"
                   Text="{DynamicResource Settings.Theme}"
                   VerticalAlignment="Center"/>
        <ComboBox Grid.Row="8" Grid.Column="1"
                  x:Name="ThemeBox"
                  Style="{StaticResource OutlinedComboBox}"/>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Grid.Column="0"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn.Cancel}" Width="80" IsCancel="True"
                    Style="{StaticResource FlatButton}"
                    Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Btn.Ok}" Width="80" IsDefault="True"
                    Click="OK_Click"
                    Style="{StaticResource RaisedButton}"/>
        </StackPanel>
    </Grid>
</views:DialogWindowBase>
